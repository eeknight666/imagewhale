# 图床共享系统配置

# 管理员账号
ADMIN_USERNAME=admin

# 服务器配置
HOST=0.0.0.0
PORT=5189

# 上传限制
MAX_FILE_SIZE=209715200
PROJECT_STORAGE_LIMIT=1073741824

# JWT配置 (首次运行自动生成)
JWT_SECRET=
JWT_EXPIRE_HOURS=24

# 数据库路径
DATABASE_PATH=./data/imagehub.db

# 上传目录
UPLOAD_DIR=./uploads
THUMBNAIL_DIR=./thumbnails

# 缩略图尺寸
THUMBNAIL_SIZE=300
